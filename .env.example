# BOB - Environment Variables Configuration
# Copie este arquivo para .env e preencha com seus valores

# ============================================
# GitLab Configuration
# ============================================
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=seu-token-gitlab-aqui

# Como obter o token:
# 1. GitLab > Settings > Access Tokens
# 2. Crie token com scopes: api, read_api, read_repository
# 3. Copie o token gerado

# ============================================
# Slack Configuration
# ============================================
SLACK_BOT_TOKEN=xoxb-seu-token-bot-slack-aqui
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T00000000/B00000000/XXXXXXXXXXXXXXXXXXXX

# Como obter tokens Slack:
# Bot Token:
# 1. https://api.slack.com/apps
# 2. Crie novo app ou selecione existente
# 3. OAuth & Permissions > Bot User OAuth Token
#
# Webhook URL:
# 1. https://api.slack.com/apps
# 2. Incoming Webhooks > Add New Webhook to Workspace
# 3. Selecione canal e copie URL

# ============================================
# Optional Configuration
# ============================================

# Ambiente (development, staging, production)
BOB_ENV=development

# Nível de log (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# Timeout para análise (segundos)
ANALYSIS_TIMEOUT=600

# ============================================
# Database (se necessário para métricas)
# ============================================
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=bob_metrics
# DB_USER=bob
# DB_PASSWORD=senha-segura-aqui